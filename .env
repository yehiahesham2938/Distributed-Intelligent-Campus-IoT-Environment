# Environment variables
LOG_LEVEL=INFO

# MQTT
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_TLS_ENABLED=0
MQTT_TLS_PORT=8883
MQTT_CA_CERT=secrets/ca.crt
MQTT_CREDENTIALS_CSV=secrets/mqtt_credentials.csv

# CoAP
COAP_BIND_HOST=0.0.0.0
COAP_BASE_PORT=5683
COAP_DTLS_ENABLED=0
COAP_PSK_JSON=secrets/coap_psk.json

# RTT metrics
RTT_CSV_PATH=data/rtt_metrics.csv

# ThingsBoard (used by scripts/provision_thingsboard.py)
TB_URL=http://localhost:9090
TB_USERNAME=tenant@thingsboard.org
TB_PASSWORD=tenant

# Simulation
PUBLISH_INTERVAL=5
TIME_ACCELERATION=1
STARTUP_JITTER=20

# Fleet
NUM_FLOORS=10
ROOMS_PER_FLOOR=20

# Outside environment
OUTSIDE_TEMP=30
OUTSIDE_TEMP_AMPLITUDE=5
OUTSIDE_HUMIDITY=60
OUTSIDE_HUMIDITY_AMPLITUDE=10

# Thermal model
THERMAL_ALPHA=0.01
THERMAL_BETA=0.5

# Persistence
SQLITE_SAVE_INTERVAL_SECONDS=30
# SQLITE_DB_PATH=data/campus_iot.db

# Fault simulation
FAULT_RATE=0.02
SENSOR_DRIFT_RATE=0.02
FROZEN_SENSOR_RATE=0.02
TELEMETRY_DELAY_RATE=0.02
NODE_DROPOUT_RATE=0.02
SENSOR_DRIFT_STEP_MAX=0.05
FROZEN_SENSOR_DURATION_SECONDS=30
TELEMETRY_DELAY_MIN_SECONDS=1
TELEMETRY_DELAY_MAX_SECONDS=3
NODE_DROPOUT_DURATION_SECONDS=30
